# ---- Supabase ----
# Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role —— 只在服务端使用，绝不要提交到 git，绝不要带 NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Site ----
# OAuth 回调需要绝对 URL，本地就是 http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Brand (单一口径；所有页面从 data/site.ts 读) ----
NEXT_PUBLIC_BRAND_NAME=YourBrand
NEXT_PUBLIC_BRAND_DOMAIN=yourdomain.com
NEXT_PUBLIC_SALES_EMAIL=sales@yourdomain.com
NEXT_PUBLIC_TELEGRAM=@yourbrand_support

# ---- API Gateway ----
# 展示给客户的 Base URL（Docs / Dashboard / 邮件模板都读这个）
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/v1

# ---- Stripe Payment Links（Batch 2） ----
# 在 Stripe Dashboard → Payment Links 创建后，粘贴完整 URL 到这里
# 留空时，Pricing 的 Get Access 按钮会自动 fallback 到 /contact，不会破坏体验
NEXT_PUBLIC_STRIPE_LINK_STARTER=
NEXT_PUBLIC_STRIPE_LINK_PRO=
